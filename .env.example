# Copy to .env.local and fill in real values (.env.local is gitignored).

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>/?appName=<app>
MONGODB_DB=revera_studio

# Admin authentication (server-only — never exposed to the client)
ADMIN_PASSWORD=change-me
# Any long random string; used to sign the admin session cookie.
ADMIN_SECRET=generate-with-openssl-rand-hex-32
